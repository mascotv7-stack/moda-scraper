# ─── DUFFEL (Vols) ───────────────────────────────────────────────────────────
# Inscription : https://app.duffel.com/signup
# Gratuit pour la recherche — paye seulement si tu actives le booking
DUFFEL_API_KEY=duffel_test_your_key_here

# ─── LITEAPI (Hôtels) ────────────────────────────────────────────────────────
# Inscription : https://dashboard.liteapi.travel/register/
# Free tier : 1 000 req/mois — sand_xxx pour sandbox, live_xxx pour production
LITEAPI_KEY=sand_your_key_here

# ─── SNCF (Trains France) ────────────────────────────────────────────────────
# Inscription : https://numerique.sncf.com/startup/api/
# Free tier : 90 000 req/mois — largement suffisant
SNCF_API_KEY=your_sncf_api_key

# ─── SERVEUR ─────────────────────────────────────────────────────────────────
PORT=3100

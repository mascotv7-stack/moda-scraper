# ─── DUFFEL (Vols) ───────────────────────────────────────────────────────────
# Inscription : https://app.duffel.com/signup
# Gratuit pour la recherche — paye seulement si tu actives le booking
DUFFEL_API_KEY=duffel_test_your_key_here

# ─── AMADEUS (Hôtels uniquement — temporaire jusqu'au 17/07/2026) ────────────
# À remplacer par Booking.com Affiliate API quand approuvé
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_ENV=test

# ─── SNCF (Trains France) ────────────────────────────────────────────────────
# Inscription gratuite : https://numerique.sncf.com/startup/api/
# Free tier : 90 000 req/mois — largement suffisant
SNCF_API_KEY=your_sncf_api_key

# ─── SERVEUR ─────────────────────────────────────────────────────────────────
PORT=3100
